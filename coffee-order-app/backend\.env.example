# WECO CAFE 后端API环境变量配置

# 服务器配置
PORT=3000
NODE_ENV=production

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/weco_cafe
# 或者使用MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/weco_cafe

# 微信小程序配置
WECHAT_APPID=wx9b0a73bc3b4e5d62
WECHAT_SECRET=your_app_secret_here

# 微信支付配置
WXPAY_MCHID=1230000100
WXPAY_KEY=your_wxpay_key_here
WXPAY_CERT_PATH=./certs/apiclient_cert.pem
WXPAY_KEY_PATH=./certs/apiclient_key.pem

# TENPAY GLOBAL 配置（澳门币支付）
TENPAY_MERCHANT_ID=MACAU123456
TENPAY_API_KEY=your_tenpay_key_here
TENPAY_CURRENCY=MOP
TENPAY_REGION=MO

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5mb

# 缓存配置
REDIS_URL=redis://localhost:6379

# 日志配置
LOG_LEVEL=info
LOG_PATH=./logs